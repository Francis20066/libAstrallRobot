<?xml version="1.0"?>
<robot name="astrall_robot_dog">
  <material name="astrall_body">
    <color rgba="0.16 0.19 0.22 1.0"/>
  </material>
  <material name="astrall_panel">
    <color rgba="0.15 0.45 0.72 1.0"/>
  </material>
  <material name="astrall_limb">
    <color rgba="0.06 0.07 0.08 1.0"/>
  </material>
  <material name="astrall_sensor">
    <color rgba="0.02 0.02 0.02 1.0"/>
