  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.32" rpy="0 0 0"/>
      <geometry>
        <box size="0.82 0.34 0.18"/>
      </geometry>
      <material name="astrall_body"/>
    </visual>
    <visual>
      <origin xyz="0.16 0 0.42" rpy="0 0 0"/>
      <geometry>
        <box size="0.34 0.28 0.035"/>
